      .gloabal switch_context
      .section .text
  switch_context:
    //rdi=old, rsi=new
    //Save old stack
    mov [rdi + 0x00], rsp
    mov [rdi + 0x08], rbx
    mov [rdi + 0x10], rbp
    mov [rdi + 0x18], r12
    mov [rdi + 0x20], r13
    mov [rdi + 0x28], r14
    mov [rdi + 0x30], r15

    //Load new stack
    mov rsp, [rdi + 0x00]
    mov rbx, [rdi + 0x08]
    mov rbp, [rdi + 0x10]
    mov r12, [rdi + 0x18]
    mov r13, [rdi + 0x20]
    mov r14, [rdi + 0x28]
    mov r15, [rdi + 0x30]
